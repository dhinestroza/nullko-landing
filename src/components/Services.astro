---
const services = [
  {
    num: "01",
    title: "Desarrollo Web",
    desc: "Construimos aplicaciones web rápidas y escalables pensadas para tu negocio, no plantillas genéricas. Desde dashboards complejos hasta plataformas de cara al cliente, cuidamos cada capa: arquitectura, rendimiento y mantenibilidad a largo plazo.",
    highlight: "De la idea al producto en producción.",
  },
  {
    num: "02",
    title: "Apps Móviles",
    desc: "Diseñamos y desarrollamos experiencias móviles que los usuarios realmente disfrutan. iOS, Android o ambas — nos enfocamos en interacciones fluidas, funcionamiento sin conexión y ese nivel de pulido que se gana las cinco estrellas.",
    highlight: "Experiencia nativa. Eficiencia multiplataforma.",
  },
  {
    num: "03",
    title: "Software Empresarial",
    desc: "Herramientas internas, automatización de procesos y sistemas a medida que eliminan la fricción que frena a tu equipo. Reemplazamos hojas de cálculo y procesos manuales con software que crece con tu operación y se adapta a medida que evolucionas.",
    highlight: "Construido para tu proceso. No al revés.",
  },
  {
    num: "04",
    title: "Consultoría Técnica",
    desc: "¿No sabes por dónde empezar o tienes un sistema que te está limitando? Auditamos tu setup actual, identificamos los cuellos de botella y te entregamos un plan de acción claro — sin tecnicismos innecesarios ni rodeos.",
    highlight: "Consejos honestos. Sin relleno.",
  },
];
---

<section class="services" id="servicios">
  <div class="services__inner">
    <div class="services__header" data-reveal>
      <span class="label">— Servicios</span>
      <h2 class="section-title">Lo que<br/><em>construimos</em></h2>
    </div>

    <div class="services__grid">
      {services.map((s, i) => (
        <div class="service-card" data-reveal data-delay={i * 80}>
          <span class="service-card__num">{s.num}</span>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <span class="service-card__highlight">{s.highlight}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--border);
  }
  .services__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .services__header { margin-bottom: 3rem; }

  .label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text);
  }
  .section-title em {
    font-style: normal;
    color: #6b7280;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .service-card {
    background: var(--bg);
    padding: 2.5rem;
    transition: background 0.25s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .service-card:hover { background: var(--surface); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-card__num {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: #6b7280;
    font-family: var(--font-mono);
  }
  .service-card__title {
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    font-weight: 700;
    color: #e8eaed;
    margin-top: 0.25rem;
  }
  .service-card__desc {
    font-size: clamp(0.8rem, 1.5vw, 0.88rem);
    color: #9ca3af;
    line-height: 1.8;
    flex: 1;
  }
  .service-card__highlight {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-top: 0.5rem;
    display: block;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .service-card:hover .service-card__highlight {
    opacity: 1;
    transform: translateY(0);
  }


  @media (max-width: 900px) {
    .service-card { padding: 2rem; }
  }

  @media (max-width: 640px) {
    .services { padding: 4rem 1rem; }
    .services__grid {
      grid-template-columns: 1fr;
    }
    .service-card { padding: 1.75rem 1.25rem; }
    .service-card__highlight {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>