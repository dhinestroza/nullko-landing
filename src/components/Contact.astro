---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section class="contact" id="contacto">
  <div class="contact__inner">
    <div class="contact__left" data-reveal>
      <span class="contact__label">— Contacto</span>
      <h2 class="contact__heading">¿Tienes un proyecto<br/><em>en mente?</em></h2>
      <p class="contact__desc">
        Cuéntanos qué quieres construir. Respondemos en menos de 24 horas
        con una propuesta clara y sin rodeos.
      </p>

      <div class="contact__details">
        <div class="contact__detail">
          <span class="contact__detail-label">Email</span>
          <a href="mailto:hola@nullko.co" class="contact__detail-value">hola@nullko.co</a>
        </div>
        <div class="contact__detail">
          <span class="contact__detail-label">WhatsApp</span>
          <a href="https://wa.me/573000000000" class="contact__detail-value">+57 300 000 0000</a>
        </div>
        <div class="contact__detail">
          <span class="contact__detail-label">Ubicación</span>
          <span class="contact__detail-value">Bogotá, Colombia 🇨🇴</span>
        </div>
      </div>
    </div>

    <div class="contact__form-wrap" data-reveal data-delay="100">
      <form
        class="contact__form"
        action="https://api.web3forms.com/submit"
        method="POST"
        id="contact-form"
      >
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value="Nuevo contacto desde nullko.co" />
        <input type="hidden" name="from_name" value="Nullko Landing" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Nombre</label>
            <input class="form-input" type="text" name="name" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" name="email" placeholder="tu@empresa.com" required />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Tipo de proyecto</label>
          <select class="form-input" name="tipo_proyecto" required>
            <option value="">Selecciona una opción</option>
            <option>Aplicación web</option>
            <option>App móvil</option>
            <option>Software empresarial</option>
            <option>Consultoría técnica</option>
            <option>Otro</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Cuéntanos</label>
          <textarea class="form-input form-textarea" name="message" placeholder="Describe tu proyecto brevemente..." required></textarea>
        </div>

        <button class="form-submit" type="submit" id="submit-btn">
          Enviar mensaje →
        </button>

        <!-- Mensajes de estado -->
        <div class="form-status" id="form-success" style="display:none">
          ✓ Mensaje enviado. Te respondemos pronto.
        </div>
        <div class="form-status form-status--error" id="form-error" style="display:none">
          ✕ Algo salió mal. Intenta de nuevo.
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Enviando...';
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const json = await res.json();

      if (json.success) {
        successMsg.style.display = 'block';
        errorMsg.style.display = 'none';
        form.reset();
      } else {
        throw new Error('Error');
      }
    } catch {
      errorMsg.style.display = 'block';
      successMsg.style.display = 'none';
    } finally {
      submitBtn.textContent = 'Enviar mensaje →';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .contact {
    padding: 6rem 1.5rem;
    border-top: 1px solid #1e2328;
  }
  .contact__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }

  .contact__label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #00e5a0;
    display: block;
    margin-bottom: 1rem;
  }
  .contact__heading {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #e8eaed;
    margin-bottom: 1.25rem;
  }
  .contact__heading em {
    font-style: normal;
    color: #6b7280;
  }

  .contact__desc {
    font-size: clamp(0.8rem, 1.5vw, 0.88rem);
    color: #9ca3af;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact__detail {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .contact__detail-label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #3a4048;
  }
  .contact__detail-value {
    font-size: 0.9rem;
    color: #e8eaed;
    transition: color 0.2s;
  }
  .contact__detail-value:hover { color: #00e5a0; }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #3a4048;
  }
  .form-input {
    background: #0f1215;
    border: 1px solid #1e2328;
    border-radius: 2px;
    color: #e8eaed;
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
    appearance: none;
  }
  .form-input:focus { border-color: #00e5a0; }
  .form-input::placeholder { color: #3a4048; }
  .form-input option { background: #0f1215; color: #e8eaed; }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-submit {
    background: #00e5a0;
    color: #080a0c;
    border: none;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1rem 2rem;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    width: 100%;
  }
  .form-submit:hover:not(:disabled) {
    background: #00ffb3;
    transform: translateY(-1px);
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    font-size: 0.78rem;
    padding: 0.75rem 1rem;
    border-radius: 2px;
    border: 1px solid #00e5a0;
    color: #00e5a0;
    letter-spacing: 0.04em;
  }
  .form-status--error {
    border-color: #ff4444;
    color: #ff4444;
  }

  @media (max-width: 900px) {
    .contact__inner { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 640px) {
    .contact { padding: 4rem 1rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>